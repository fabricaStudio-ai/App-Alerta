{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Informações básicas da usuária e configurações de segurança.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID único do Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "emergencyContacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "phone": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SecurityEvent": {
      "title": "Security Event",
      "description": "Registro de um incidente de segurança ou pedido de ajuda.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "riskLevel": { "type": "integer" },
        "userMessage": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "decision": { "type": "object" },
        "evidenceUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["ativo", "pos_evento"] }
      },
      "required": ["userId", "timestamp", "riskLevel"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfis de usuários"
    },
    "/events/{eventId}": {
      "schema": "SecurityEvent",
      "description": "Incidentes de segurança"
    }
  }
}
